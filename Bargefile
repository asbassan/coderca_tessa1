FROM python:3.11-windowsservercore-ltsc2022
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
WORKDIR C:\app
COPY pyproject.toml ./
COPY README.md ./
COPY src ./src
COPY config ./config
COPY data ./data
RUN python -m pip install --upgrade pip && python -m pip install --no-cache-dir -e .
RUN powershell -Command New-Item -ItemType Directory -Force C:\app\artifacts, C:\app\runlogs
CMD ["coderca_tessa1", "init"]
